# MySQL_URL=jdbc:mysql://localhost:3306/marketplace_db?useSSL=false&serverTimezone=Asia/Kolkata&allowPublicKeyRetrieval=true
MYSQL_URL=jdbc:mysql://mysql:3306/marketplace_db?useSSL=false&serverTimezone=Asia/Kolkata&allowPublicKeyRetrieval=true
MYSQL_USER=marketplace_user
MYSQL_PASSWORD=Marketplace@2024!
MYSQL_ROOT_PASSWORD=Root@2024!Secure
MYSQL_DATABASE=marketplace_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Elasticsearch
ES_URL=http://elasticsearch:9200

# JWT (CHANGE IN PRODUCTION - minimum 64 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-change-this-in-production-now

# Razorpay (Get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_CHANGE_ME

# Twilio SMS OTP (Get from https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Google OAuth (Get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Gemini AI (Get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# AWS S3 (Get from AWS Console)
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=marketplace-uploads
AWS_REGION=ap-south-1

# SMTP Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api
